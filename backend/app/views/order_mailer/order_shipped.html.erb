<!DOCTYPE html>
<html>
<head>
  <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body style="margin:0;padding:0;background-color:#f5f0eb;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f5f0eb;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:580px;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg,#0d9488 0%,#0f766e 60%,#44403c 100%);padding:40px 48px;text-align:center;">
              <h1 style="margin:0;color:#ffffff;font-size:32px;font-weight:800;letter-spacing:-0.5px;">TalkieToys</h1>
              <p style="margin:8px 0 0;color:rgba(255,255,255,0.8);font-size:14px;letter-spacing:0.5px;text-transform:uppercase;">Your Order is on its Way</p>
              <div style="width:48px;height:3px;background:rgba(255,255,255,0.4);border-radius:2px;margin:16px auto 0;"></div>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background:#ffffff;padding:48px;">
              <h2 style="margin:0 0 8px;color:#1c1917;font-size:22px;font-weight:700;">Great news, <%= @user.name %>!</h2>
              <p style="margin:0 0 24px;color:#57534e;font-size:15px;line-height:1.7;">
                Your order <strong style="color:#0d9488;"><%= @order.order_number %></strong> has been shipped and is on its way to you.
              </p>

              <% if @order.tracking_number.present? %>
                <!-- Tracking Box -->
                <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f5f0eb;border-radius:10px;margin:0 0 24px;">
                  <tr>
                    <td style="padding:24px;text-align:center;">
                      <p style="margin:0 0 8px;color:#78716c;font-size:13px;">Tracking Number</p>
                      <p style="margin:0 0 16px;color:#0d9488;font-size:22px;font-weight:800;letter-spacing:2px;font-family:monospace;"><%= @order.tracking_number %></p>
                      <p style="margin:0;color:#78716c;font-size:13px;">Use this number to track your shipment with the courier</p>
                    </td>
                  </tr>
                </table>
              <% end %>

              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f5f0eb;border-radius:10px;margin:0 0 32px;">
                <tr>
                  <td style="padding:20px 24px;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding:4px 0;">
                          <span style="color:#78716c;font-size:13px;">Order Number</span><br>
                          <span style="color:#1c1917;font-size:14px;font-weight:600;"><%= @order.order_number %></span>
                        </td>
                        <td style="padding:4px 0;text-align:right;">
                          <span style="color:#78716c;font-size:13px;">Estimated Delivery</span><br>
                          <span style="color:#1c1917;font-size:14px;font-weight:600;">3–5 business days</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <div style="background:#fffbeb;border-left:4px solid #f59e0b;border-radius:0 8px 8px 0;padding:14px 18px;">
                <p style="margin:0;font-size:13px;color:#78350f;line-height:1.6;">
                  If you have any questions about your delivery, please contact our support team.
                </p>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f5f0eb;padding:28px 48px;text-align:center;border-top:1px solid #e7e5e4;">
              <p style="margin:0 0 4px;color:#a8a29e;font-size:12px;">&copy; <%= Date.current.year %> TalkieToys. All rights reserved.</p>
              <p style="margin:0;font-size:12px;">
                <a href="https://talkietoyz.shop" style="color:#0d9488;text-decoration:none;font-weight:600;">talkietoyz.shop</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
