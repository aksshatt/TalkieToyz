<!DOCTYPE html>
<html>
<head>
  <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body style="margin:0;padding:0;background-color:#f5f0eb;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f5f0eb;">
    <tr>
      <td align="center" style="padding:40px 16px;">
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:580px;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg,#0d9488 0%,#0f766e 60%,#44403c 100%);padding:40px 48px;text-align:center;">
              <h1 style="margin:0;color:#ffffff;font-size:32px;font-weight:800;letter-spacing:-0.5px;">TalkieToys</h1>
              <p style="margin:8px 0 0;color:rgba(255,255,255,0.8);font-size:14px;letter-spacing:0.5px;text-transform:uppercase;">Order Confirmed</p>
              <div style="width:48px;height:3px;background:rgba(255,255,255,0.4);border-radius:2px;margin:16px auto 0;"></div>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background:#ffffff;padding:48px;">
              <h2 style="margin:0 0 8px;color:#1c1917;font-size:22px;font-weight:700;">Thank you, <%= @user.name %>!</h2>
              <p style="margin:0 0 24px;color:#57534e;font-size:15px;line-height:1.7;">
                We've received your order and it's being processed. We'll notify you once it's shipped.
              </p>

              <!-- Order Info -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f5f0eb;border-radius:10px;margin:0 0 24px;">
                <tr>
                  <td style="padding:20px 24px;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td style="padding:4px 0;">
                          <span style="color:#78716c;font-size:13px;">Order Number</span><br>
                          <span style="color:#0d9488;font-size:16px;font-weight:700;"><%= @order.order_number %></span>
                        </td>
                        <td style="padding:4px 0;text-align:right;">
                          <span style="color:#78716c;font-size:13px;">Order Date</span><br>
                          <span style="color:#1c1917;font-size:14px;font-weight:600;"><%= @order.created_at.strftime('%b %d, %Y') %></span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Items -->
              <p style="margin:0 0 12px;color:#1c1917;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Items Ordered</p>
              <% @order.order_items.each do |item| %>
                <table width="100%" cellpadding="0" cellspacing="0" border="0" style="border-bottom:1px solid #f5f0eb;">
                  <tr>
                    <td style="color:#1c1917;font-size:14px;font-weight:600;padding:10px 0;"><%= item.item_name %></td>
                    <td style="color:#57534e;font-size:14px;text-align:right;padding:10px 0;">
                      <%= item.quantity %> &times; &#8377;<%= '%.0f' % item.unit_price %>
                    </td>
                  </tr>
                </table>
              <% end %>

              <!-- Totals -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:16px 0 24px;">
                <tr>
                  <td style="color:#78716c;font-size:14px;padding:4px 0;">Subtotal</td>
                  <td style="color:#57534e;font-size:14px;text-align:right;padding:4px 0;">&#8377;<%= '%.0f' % @order.subtotal %></td>
                </tr>
                <% if @order.discount.to_f > 0 %>
                  <tr>
                    <td style="color:#78716c;font-size:14px;padding:4px 0;">Discount</td>
                    <td style="color:#16a34a;font-size:14px;text-align:right;padding:4px 0;">-&#8377;<%= '%.0f' % @order.discount %></td>
                  </tr>
                <% end %>
                <tr>
                  <td style="color:#78716c;font-size:14px;padding:4px 0;">Shipping</td>
                  <td style="color:#57534e;font-size:14px;text-align:right;padding:4px 0;">&#8377;<%= '%.0f' % @order.shipping_cost %></td>
                </tr>
                <tr>
                  <td colspan="2" style="border-top:2px solid #e7e5e4;padding-top:8px;"></td>
                </tr>
                <tr>
                  <td style="color:#1c1917;font-size:16px;font-weight:700;padding:4px 0;">Total</td>
                  <td style="color:#0d9488;font-size:18px;font-weight:800;text-align:right;padding:4px 0;">&#8377;<%= '%.0f' % @order.total %></td>
                </tr>
              </table>

              <!-- Shipping Address -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f5f0eb;border-radius:10px;margin:0 0 32px;">
                <tr>
                  <td style="padding:20px 24px;">
                    <p style="margin:0 0 8px;color:#0f766e;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Shipping To</p>
                    <p style="margin:0;color:#57534e;font-size:14px;line-height:1.8;">
                      <%= @order.shipping_address['name'] %><br>
                      <%= @order.shipping_address['address_line1'] %><br>
                      <% if @order.shipping_address['address_line2'].present? %>
                        <%= @order.shipping_address['address_line2'] %><br>
                      <% end %>
                      <%= @order.shipping_address['city'] %>, <%= @order.shipping_address['state'] %> <%= @order.shipping_address['zip_code'] %><br>
                      Phone: <%= @order.shipping_address['phone'] %>
                    </p>
                  </td>
                </tr>
              </table>

              <div style="background:#fffbeb;border-left:4px solid #f59e0b;border-radius:0 8px 8px 0;padding:14px 18px;">
                <p style="margin:0;font-size:13px;color:#78350f;line-height:1.6;">
                  We'll send you a shipping confirmation with your tracking number once your order is on its way.
                </p>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f5f0eb;padding:28px 48px;text-align:center;border-top:1px solid #e7e5e4;">
              <p style="margin:0 0 4px;color:#a8a29e;font-size:12px;">&copy; <%= Date.current.year %> TalkieToys. All rights reserved.</p>
              <p style="margin:0;font-size:12px;">
                <a href="https://talkietoyz.shop" style="color:#0d9488;text-decoration:none;font-weight:600;">talkietoyz.shop</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
