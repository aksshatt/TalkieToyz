<!DOCTYPE html>
<html>
<head>
  <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body style="margin:0;padding:0;background-color:#f5f0eb;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">

  <!-- Wrapper -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f5f0eb;">
    <tr>
      <td align="center" style="padding:40px 16px;">

        <!-- Card -->
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:580px;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg,#0d9488 0%,#0f766e 60%,#44403c 100%);padding:40px 48px;text-align:center;">
              <h1 style="margin:0;color:#ffffff;font-size:32px;font-weight:800;letter-spacing:-0.5px;">TalkieToys</h1>
              <p style="margin:8px 0 0;color:rgba(255,255,255,0.8);font-size:14px;letter-spacing:0.5px;text-transform:uppercase;">Password Reset Request</p>
              <!-- Decorative line -->
              <div style="width:48px;height:3px;background:rgba(255,255,255,0.4);border-radius:2px;margin:16px auto 0;"></div>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="background:#ffffff;padding:48px;">

              <h2 style="margin:0 0 8px;color:#1c1917;font-size:22px;font-weight:700;">Hi <%= @user.name %>,</h2>
              <p style="margin:0 0 24px;color:#57534e;font-size:15px;line-height:1.7;">
                We received a request to reset the password for your TalkieToys account associated with
                <strong style="color:#0d9488;"><%= @user.email %></strong>.
              </p>

              <p style="margin:0 0 32px;color:#57534e;font-size:15px;line-height:1.7;">
                Click the button below to reset your password. This link is valid for <strong style="color:#1c1917;">6 hours</strong>.
              </p>

              <!-- Button -->
              <div style="text-align:center;margin:0 0 32px;">
                <a href="<%= @reset_url %>"
                   style="display:inline-block;padding:16px 40px;background-color:#0d9488;color:#ffffff;text-decoration:none;border-radius:10px;font-weight:700;font-size:16px;letter-spacing:0.3px;box-shadow:0 4px 12px rgba(13,148,136,0.35);">
                  Reset My Password
                </a>
              </div>

              <!-- Fallback link -->
              <p style="margin:0 0 8px;color:#78716c;font-size:13px;">If the button doesn't work, copy and paste this link into your browser:</p>
              <div style="background:#f5f0eb;border:1px solid #e7e5e4;border-radius:8px;padding:12px 16px;font-family:monospace;font-size:12px;word-break:break-all;color:#57534e;margin:0 0 32px;">
                <%= @reset_url %>
              </div>

              <!-- Warning -->
              <div style="background:#fffbeb;border-left:4px solid #f59e0b;border-radius:0 8px 8px 0;padding:14px 18px;">
                <p style="margin:0;font-size:13px;color:#78350f;line-height:1.6;">
                  <strong>Didn't request this?</strong> If you didn't request a password reset, you can safely ignore this email. Your password will remain unchanged.
                </p>
              </div>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f5f0eb;padding:28px 48px;text-align:center;border-top:1px solid #e7e5e4;">
              <p style="margin:0 0 4px;color:#a8a29e;font-size:12px;">&copy; <%= Date.current.year %> TalkieToys. All rights reserved.</p>
              <p style="margin:0;font-size:12px;">
                <a href="https://talkietoyz.shop" style="color:#0d9488;text-decoration:none;font-weight:600;">talkietoyz.shop</a>
              </p>
            </td>
          </tr>

        </table>
        <!-- End Card -->

      </td>
    </tr>
  </table>

</body>
</html>
